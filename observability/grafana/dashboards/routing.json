{
  "title": "Routing Distribution",
  "uid": "routing-distribution",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "timezone": "browser",
  "tags": ["ai-inference", "routing"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "piechart",
      "title": "Request Share by Instance",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(gateway_routing_decisions_total[1h])) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ],
      "options": { "pieType": "pie", "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests per Instance (rate)",
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(gateway_routing_decisions_total[1m])) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate per Instance",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(gateway_errors_total[1m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency per Model",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(gateway_request_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p95 {{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Instance Summary (last 5 min)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(gateway_routing_decisions_total[5m])) by (instance)",
          "legendFormat": "{{instance}}",
          "instant": true
        }
      ],
      "options": { "footer": { "show": false } },
      "transformations": [{ "id": "labelsToFields", "options": {} }]
    }
  ]
}
