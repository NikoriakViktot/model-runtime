{
  "title": "Node Health & GPU",
  "uid": "node-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "timezone": "browser",
  "tags": ["ai-inference", "node", "gpu"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "GPU Memory Used %",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_gpu_used_mb / node_gpu_total_mb * 100",
          "legendFormat": "{{node_id}} GPU{{gpu_index}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "GPU Free Memory (MB)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_gpu_free_mb",
          "legendFormat": "{{node_id}} GPU{{gpu_index}}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "orientation": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 4000 },
              { "color": "green", "value": 8000 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Heartbeat Age (seconds)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "time() - node_last_heartbeat_timestamp_seconds",
          "legendFormat": "{{node_id}}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GPU Memory Free Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_gpu_free_mb",
          "legendFormat": "{{node_id}} GPU{{gpu_index}} free"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_gpu_used_mb",
          "legendFormat": "{{node_id}} GPU{{gpu_index}} used"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Local Ensure Latency (node → MRM)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(node_local_ensure_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p50 {{model}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(node_local_ensure_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p99 {{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Local Ensures by Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_local_ensures_total[1m])) by (model, status)",
          "legendFormat": "{{model}} — {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GPU Memory Used % Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_gpu_used_mb / node_gpu_total_mb * 100",
          "legendFormat": "{{node_id}} GPU{{gpu_index}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    }
  ]
}
